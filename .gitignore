# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent git pollution.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a vitualenv, it may cause conflict.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed
# pdm.lock
#   pdm build standard retains local directory for pdm-backed projects
.pdm-plugins/

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

